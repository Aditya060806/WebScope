# WebScope Docker environment example

# Host port mapping is controlled in docker-compose.yml (default 3000)
WEBSCOPE_PORT=3000
WEBSCOPE_COLS=100
WEBSCOPE_TIMEOUT=30000
WEBSCOPE_NETWORK_LOG_LIMIT=2000
WEBSCOPE_MAX_SESSIONS=20
WEBSCOPE_SESSION_TTL_MS=1800000
WEBSCOPE_RATE_LIMIT_WINDOW_MS=60000
WEBSCOPE_RATE_LIMIT_MAX=120
WEBSCOPE_RATE_LIMIT_STORE=memory
WEBSCOPE_REDIS_URL=
WEBSCOPE_API_KEY_STORE=file
WEBSCOPE_API_KEYS_FILE=/app/state/api-keys.json
WEBSCOPE_AUDIT_LOG=true

# Optional: protect API endpoints with bearer token
WEBSCOPE_API_KEY=

# Optional: scoped API keys JSON (overrides single-key model)
# Example: {"admin-token":{"id":"admin","scopes":["admin","read","write"],"rate_limit":300},"reader-token":{"id":"reader","scopes":["read"],"rate_limit":60}}
WEBSCOPE_API_KEYS_JSON=

# Optional: restrict browser clients for CORS
WEBSCOPE_CORS_ORIGIN=*

# Optional: HTTP/SOCKS proxy for outbound browsing
WEBSCOPE_PROXY=
