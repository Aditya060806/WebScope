{
  "name": "webscope",
  "description": "Text-grid web browser for AI agents. Renders pages as structured text with interactive element references instead of screenshots.",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "webscope_navigate",
        "description": "Navigate to a URL and render the page as a structured text grid.",
        "parameters": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "The URL to navigate to"
            },
            "headers": {
              "type": "object",
              "description": "Custom HTTP headers (e.g., {\"Authorization\": \"Bearer token\"})"
            },
            "device": {
              "type": "string",
              "description": "Device profile for emulation (e.g., iphone14, pixel7, ipadpro)"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "url"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_click",
        "description": "Click an interactive element identified by its [ref] number.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number (e.g., 3 for [3])"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_type",
        "description": "Type text into an input field identified by its [ref] number.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number of the input field"
            },
            "text": {
              "type": "string",
              "description": "Text to enter into the field"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref",
            "text"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_select",
        "description": "Select an option from a dropdown by its [ref] number.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number of the dropdown"
            },
            "value": {
              "type": "string",
              "description": "Option value or visible text to select"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref",
            "value"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_upload",
        "description": "Upload a file to a file input element.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number of the file input"
            },
            "path": {
              "type": "string",
              "description": "Absolute file path to upload"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref",
            "path"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_press",
        "description": "Press a keyboard key (Enter, Tab, Escape, ArrowDown, etc.).",
        "parameters": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string",
              "description": "Key name (e.g., Enter, Tab, Escape)"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "key"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_scroll",
        "description": "Scroll the current page.",
        "parameters": {
          "type": "object",
          "properties": {
            "direction": {
              "type": "string",
              "enum": [
                "up",
                "down",
                "top"
              ],
              "description": "Scroll direction"
            },
            "amount": {
              "type": "integer",
              "description": "Pages to scroll (default: 1)",
              "default": 1
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "direction"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_snapshot",
        "description": "Re-render the current page without navigating.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_storage_save",
        "description": "Save cookies/localStorage/sessionStorage to a storageState JSON file.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute output path for storage state JSON"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "path"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_storage_load",
        "description": "Load cookies/localStorage/sessionStorage from a storageState JSON file.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute storage state path"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "path"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_wait_for",
        "description": "Wait for selector/text/url state during multi-step flows.",
        "parameters": {
          "type": "object",
          "properties": {
            "selector": {
              "type": "string",
              "description": "CSS selector to wait for"
            },
            "text": {
              "type": "string",
              "description": "Page text to wait for"
            },
            "url_includes": {
              "type": "string",
              "description": "Substring expected in URL"
            },
            "state": {
              "type": "string",
              "enum": [
                "attached",
                "detached",
                "visible",
                "hidden"
              ],
              "description": "Selector state"
            },
            "timeout_ms": {
              "type": "integer",
              "description": "Timeout milliseconds"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            },
            "poll_ms": {
              "type": "integer",
              "description": "Polling interval for text/url waits"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_assert_field",
        "description": "Assert field value/text by element ref.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number"
            },
            "expected": {
              "type": "string",
              "description": "Expected value or content"
            },
            "comparator": {
              "type": "string",
              "enum": [
                "equals",
                "includes",
                "regex",
                "not_empty"
              ],
              "description": "Comparison mode"
            },
            "attribute": {
              "type": "string",
              "description": "Optional attribute to assert"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "ref",
            "expected"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_session_list",
        "description": "List active webscope sessions and metadata.",
        "parameters": {
          "type": "object",
          "properties": {}
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_session_close",
        "description": "Close one session by session_id, or all sessions when all=true.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Session id to close (default: default)"
            },
            "all": {
              "type": "boolean",
              "description": "Close all active sessions"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_evaluate",
        "description": "Execute a JavaScript expression in the browser page and return the result.",
        "parameters": {
          "type": "object",
          "properties": {
            "script": {
              "type": "string",
              "description": "JavaScript expression to evaluate (e.g., \"document.title\")"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": ["script"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_batch",
        "description": "Execute multiple actions in sequence. Stops on first error.",
        "parameters": {
          "type": "object",
          "properties": {
            "actions": {
              "type": "array",
              "description": "Actions to execute: [{action: 'click', params: {ref: 5}}, ...]",
              "items": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": ["navigate", "click", "type", "select", "scroll", "press", "upload", "snapshot", "waitFor", "evaluate"]
                  },
                  "params": {
                    "type": "object"
                  }
                },
                "required": ["action"]
              }
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": ["actions"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_diff",
        "description": "Compare current snapshot against the previous one. Shows added, removed, and changed elements.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_find",
        "description": "Search for interactive elements by natural language query.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query (e.g., 'login button', 'email input')"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": ["query"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_network",
        "description": "Get the network request/response log. Optionally filter by type or URL pattern.",
        "parameters": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["request", "response"],
              "description": "Filter by entry type"
            },
            "resource_type": {
              "type": "string",
              "description": "Filter by resource type (document, script, xhr, fetch, etc.)"
            },
            "url_pattern": {
              "type": "string",
              "description": "Regex pattern to filter by URL"
            },
            "clear": {
              "type": "boolean",
              "description": "Clear log after retrieving"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_record_start",
        "description": "Start recording browser actions for later replay.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_record_stop",
        "description": "Stop recording browser actions.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_record_export",
        "description": "Export recorded actions as a JSON array.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_replay",
        "description": "Replay a list of recorded actions.",
        "parameters": {
          "type": "object",
          "properties": {
            "actions": {
              "type": "array",
              "description": "Array of recorded actions. If omitted, replays last recording."
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "webscope_devices",
        "description": "List available device profiles for mobile/tablet emulation.",
        "parameters": {
          "type": "object",
          "properties": {}
        }
      }
    }
  ]
}